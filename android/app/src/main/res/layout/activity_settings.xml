<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/setup_wizard_background"
  android:fitsSystemWindows="true">

  <androidx.core.widget.NestedScrollView
    android:id="@+id/settings_scroll"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="24dp"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_horizontal"
      android:orientation="vertical">

      <!-- Header -->
      <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/xemu_surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/xemu_outline_variant"
        app:strokeWidth="1dp">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="24dp">

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
              android:id="@+id/btn_settings_back"
              android:layout_width="40dp"
              android:layout_height="40dp"
              android:background="?attr/selectableItemBackgroundBorderless"
              android:contentDescription="@string/settings_back"
              android:padding="6dp"
              android:src="@android:drawable/ic_menu_revert"
              android:tint="@color/xemu_green" />

            <TextView
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_marginStart="12dp"
              android:layout_weight="1"
              android:text="@string/settings_title"
              android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium" />
          </LinearLayout>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>

      <!-- GPU Driver Section -->
      <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_gpu_driver"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/xemu_surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/xemu_outline_variant"
        app:strokeWidth="1dp">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="24dp">

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_gpu_driver_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_gpu_driver_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <TextView
            android:id="@+id/settings_gpu_driver_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/setup_wizard_path_background"
            android:text="@string/settings_gpu_driver_system"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/xemu_text_muted" />

          <TextView
            android:id="@+id/settings_gpu_not_supported"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_gpu_driver_not_supported"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="#FFAB91"
            android:visibility="gone" />

          <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_install_driver"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_gpu_driver_install"
            app:icon="@android:drawable/stat_sys_download"
            app:iconGravity="textStart"
            app:iconPadding="8dp" />

          <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
              android:id="@+id/btn_select_driver"
              style="?attr/materialButtonOutlinedStyle"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_marginEnd="4dp"
              android:layout_weight="1"
              android:text="@string/settings_gpu_driver_select"
              app:icon="@android:drawable/ic_menu_manage"
              app:iconGravity="textStart"
              app:iconPadding="8dp" />

            <com.google.android.material.button.MaterialButton
              android:id="@+id/btn_reset_driver"
              style="?attr/materialButtonOutlinedStyle"
              android:layout_width="0dp"
              android:layout_height="wrap_content"
              android:layout_marginStart="4dp"
              android:layout_weight="1"
              android:text="@string/settings_gpu_driver_reset"
              app:icon="@android:drawable/ic_menu_delete"
              app:iconGravity="textStart"
              app:iconPadding="8dp" />
          </LinearLayout>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>

      <!-- Hard Disk Section -->
      <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/xemu_surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/xemu_outline_variant"
        app:strokeWidth="1dp">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="24dp">

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_hdd_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_hdd_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_cache"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_clear_cache" />

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:text="@string/settings_clear_cache_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_recreate_hdd"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/settings_recreate_hdd" />

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:text="@string/settings_recreate_hdd_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>

      <!-- Code Cache Section (hidden while XEMU_OPT_TB_CACHE_HINTS is OFF) -->

      <!-- Display Section -->
      <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/xemu_surface"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/xemu_outline_variant"
        app:strokeWidth="1dp">

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:padding="24dp">

          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_display_title"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />

          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_show_fps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_show_fps"
            android:textColor="@color/xemu_text_muted" />

          <!-- Resolution Scale -->
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_resolution_scale"
            android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/settings_resolution_scale_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />
          <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_resolution_scale"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="1x (Native)"
            android:textColor="@color/xemu_text_muted" />

          <!-- Texture Filtering -->
          <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_filtering"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nearest"
            android:textColor="@color/xemu_text_muted" />

          <!-- Aspect Ratio -->
          <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_aspect_ratio"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Auto"
            android:textColor="@color/xemu_text_muted" />

          <!-- Unlock Frame Rate (hidden: always on) -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_unlock_framerate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

          <!-- Native Floats (Safe) -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_fp_safe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_fp_safe"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_fp_safe_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Native Floats (JIT) -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_fp_jit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_fp_jit"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_fp_jit_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Fast Fences -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_fast_fences"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_fast_fences"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_fast_fences_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Draw Reordering -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_draw_reorder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_draw_reorder"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_draw_reorder_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Draw Merging -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_draw_merge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_draw_merge"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_draw_merge_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Bindless Textures -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_bindless_textures"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_bindless_textures"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_bindless_textures_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Async Compile -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_async_compile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_async_compile"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_async_compile_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Frame Skip -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_frame_skip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_frame_skip"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_frame_skip_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Submit Frames (Buffering) -->
          <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_submit_frames"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Double (2)"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_submit_frames_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Tier-1 Recompilation Threshold -->
          <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_tier1_threshold"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Default (64)"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_tier1_threshold_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Vulkan Validation Layers -->
          <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_validation_layers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_validation_layers"
            android:textColor="@color/xemu_text_muted" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="2dp"
            android:text="@string/settings_validation_layers_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />

          <!-- Clear Shader Cache -->
          <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_clear_shader_cache"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_clear_shader_cache" />
          <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:text="@string/settings_clear_shader_cache_desc"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="@color/xemu_text_muted" />
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
  </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
